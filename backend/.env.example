APP_NAME=CreativeStudio AI
APP_VERSION=1.0.0
APP_ENV=development

DATABASE_URL=postgresql+asyncpg://creativestudioai:Baguvix1%40@localhost:5432/creativestudioai
REDIS_URL=redis://localhost:6379/0

SECRET_KEY=generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Runway ML — image, video, and all media generation
RUNWAYML_API_KEY=
RUNWAYML_BASE_URL=https://api.dev.runwayml.com/v1
RUNWAYML_API_VERSION=2024-11-06
# Nano Banana 2 = gemini_image3.1_flash (pixel ratios e.g. 768:1344 for reel — not 9:16)
RUNWAYML_MODEL_IMAGE=gemini_image3.1_flash
RUNWAYML_MODEL_VIDEO=veo3.1
RUNWAYML_IMAGE_RATIO=1080:1080
RUNWAYML_VIDEO_RATIO=1080:1920
# Veo 3.1 / 3.1 Fast only accept 4, 6, or 8 (seconds). Other values are snapped automatically.
RUNWAYML_VIDEO_DURATION=8
RUNWAYML_TRANSIENT_RETRY_ATTEMPTS=3
RUNWAYML_TRANSIENT_RETRY_BASE_SEC=15
# Logo + subtitle burn-in after HeyGen (required): pip install imageio-ffmpeg
# Crop/scale reel video to full 1080x1920 (fixes HeyGen letterboxing; requires ffmpeg)
VIDEO_PORTRAIT_NORMALIZE=true
VIDEO_LOGO_REQUIRED=true
# Brand logo burned onto every reel/video (top-left landscape, bottom-right portrait).
# Priority: Brand Kit upload → DEFAULT_VIDEO_LOGO_URL → bundled file paths below.
# DEFAULT_VIDEO_LOGO_URL=/files/<tenant>/brands/logo.png
# CLICKTRENDS_LOGO_FILE=app/assets/clicktrends_logo.png
# Auto-fallback: backend/app/assets/*.png and frontend/public/traffic-radius-logo.png
DEFAULT_VIDEO_LOGO_URL=
CLICKTRENDS_LOGO_FILE=

IMAGE_GENERATION_PROVIDER=nano-banana-2
VIDEO_GENERATION_PROVIDER=veo-3.1

# OpenRouter — ad copy (Claude Haiku) + avatar scripts (Claude Sonnet 4.6)
OPENROUTER_API_KEY=
OPENROUTER_MODEL_CLAUDE=anthropic/claude-haiku-4.5
OPENROUTER_MODEL_CLAUDE_SCRIPT=anthropic/claude-sonnet-4

# HeyGen — v3 Video Agent = dynamic scenes/backgrounds; v2 = flat-color talking head only
HEYGEN_VIDEO_API=v3
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=
# JSON array — use HeyGen public look id from app.heygen.com (e.g. Vespri)
HEYGEN_AVATAR_OPTIONS=[{"id":"25777ee579284b9d9081bc95c49c5f00","label":"Vespri (Female)","gender":"female"},{"id":"Annie_Office_Standing_Front_public","label":"Annie Office Standing Front (Female)","gender":"female"},{"id":"1732832799","label":"Sofia (Female)","gender":"female"}]
HEYGEN_VOICE_OPTIONS=

# Higgsfield — image + video via platform.higgsfield.ai (Key ID + Secret from cloud dashboard)
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=
HIGGSFIELD_BASE_URL=https://platform.higgsfield.ai
HIGGSFIELD_POLL_MAX_WAIT_SECONDS=1800

META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_GRAPH_API_VERSION=v21.0

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800

CORS_ORIGINS=["http://localhost:3000"]

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
