# PostgreSQL
POSTGRES_DB=creativestudio
POSTGRES_USER=csuser
POSTGRES_PASSWORD=change_me_in_production

# Redis
REDIS_PASSWORD=change_me_in_production

# Backend (copy to backend/.env)
DATABASE_URL=postgresql+asyncpg://csuser:change_me_in_production@localhost:5432/creativestudio
REDIS_URL=redis://:change_me_in_production@localhost:6379/0
SECRET_KEY=generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
RUNWAYML_API_KEY=
RUNWAYML_BASE_URL=https://api.dev.runwayml.com/v1
RUNWAYML_API_VERSION=2024-11-06
RUNWAYML_MODEL_IMAGE=gemini_image3_pro
RUNWAYML_MODEL_VIDEO=veo3.1
IMAGE_GENERATION_PROVIDER=nano-banana-2
VIDEO_GENERATION_PROVIDER=veo-3.1
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_GRAPH_API_VERSION=v21.0
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800
CORS_ORIGINS=["http://localhost:3000"]
APP_ENV=development
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_in_production

# Frontend (copy to frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=CreativeStudio AI
